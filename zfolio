      PANEL_LINES+=(
        ""
        "$(printf "%b%s%b" "$FG_MAGENTA" "───────────────────────────── Contact ──────────────────────────────" "$RESET")"
        ""
        "$(printf "%b%-10s%b  %s" "$FG_CYAN" "email"    "$RESET" "$EMAIL")"
        ""
        "$(printf "%b%-10s%b  %s" "$FG_CYAN" "github"   "$RESET" "$GITHUB")"
        ""
        "$(printf "%b%-10s%b  %s" "$FG_CYAN" "linkedin" "$RESET" "$LINKEDIN")"
        ""
        "$(printf "%b%-10s%b  %s" "$FG_CYAN" "website"  "$RESET" "$WEBSITE")"
      )
      ;;
  esac
}

draw_panel() {
  local idx=$1
  local cols; cols=$(get_term_width)
  local rows; rows=$(get_term_height)
  local sw=$SIDEBAR_W
  local panel_x=$(( sw + 2 ))
  local pw=$(( cols - sw - 2 ))
  local chrome_start=$(( BANNER_ROWS + 1 ))
  local content_start=$(( chrome_start + 3 ))
  local content_end=$(( rows - 1 ))

  local r
  for (( r=content_start; r<=content_end; r++ )); do
    goto "$r" "$panel_x"
    clear_eol
  done

  local entry="${BROWSER_ENTRIES[$idx]}"
  build_panel_content "$entry"

  local row="$content_start"
  local line
  for line in "${PANEL_LINES[@]}"; do
    (( row > content_end )) && break
    goto "$row" "$panel_x"
    if (( PANEL_NONCENTER == 1 )); then
      printf "  %s" "$line"
    else
      local stripped; stripped=$(printf '%s' "$line" | sed 's/\x1b\[[0-9;]*m//g')
      local vlen=${#stripped}
      local lpad=$(( (pw - vlen) / 2 ))
      (( lpad < 1 )) && lpad=1
      printf "%*s%s" "$lpad" '' "$line"
    fi
    (( row++ ))
  done
}

browser_loop() {
  local selected=0
  local total=${#BROWSER_ENTRIES[@]}

  hide_cursor
  clr

  draw_chrome
  draw_sidebar "$selected"
  draw_panel   "$selected"

  while true; do
    local key; key="$(read_key)"

    case "$key" in
      $'\x1b[A')
        (( selected-- ))
        (( selected < 0 )) && selected=$(( total - 1 ))
        draw_sidebar "$selected"
        draw_panel   "$selected"
        ;;
      $'\x1b[B')
        (( selected++ ))
        (( selected >= total )) && selected=0
        draw_sidebar "$selected"
        draw_panel   "$selected"
        ;;
      [1-6])
        local n=$(( key - 1 ))
        if (( n >= 0 && n < total )); then
          selected=$n
          draw_sidebar "$selected"
          draw_panel   "$selected"
        fi
        ;;
      $'\n'|$'\r'|'')
        draw_sidebar "$selected"
        draw_panel   "$selected"
        ;;
      $'\x1b')
        show_cursor
        clr
        return
        ;;
      q|Q)
        show_cursor
        clr
        echo
        say " Thanks for stopping by. See you around." "$FG_GRAY"
        echo
        exit 0
        ;;
    esac
  done
  show_cursor
}

mode_selector() {
  while true; do
    clr
    local width; width=$(get_term_width)

    echo
    echo
    center_line "╔══════════════════════════════════╗" "$FG_RED"
    center_line "║         Zahàna | Portfolio       ║" "$FG_RED$BOLD"
    center_line "╚══════════════════════════════════╝" "$FG_RED"
    echo
    center_line "choose your experience" "$FG_WHITE"
    echo
    center_line "[ 1 ]  shell mode" "$FG_GREEN$BOLD"
    center_line "type commands like a real terminal" "$FG_GRAY"
    echo
    center_line "[ 2 ]  browser mode" "$FG_BLUE$BOLD"
    center_line "split-pane UI · arrow keys to navigate" "$FG_GRAY"
    echo
    echo

    local prompt="  your choice [1/2]: "
    local pad=$(( (width - ${#prompt}) / 2 ))
    (( pad < 0 )) && pad=0
    printf "%*s%b%s%b" "$pad" '' "$FG_YELLOW" "$prompt" "$RESET"

    local choice
    IFS= read -r choice
    choice="$(echo "$choice" | xargs 2>/dev/null || echo "$choice")"

    case "$choice" in
      1|s|S|shell)
        shell_loop
        ;;
      2|b|B|browser)
        browser_loop
        ;;
      exit|q|Q)
        exit 0
        ;;
      "")
        shell_loop
        ;;
      *)
        say "  Invalid choice. Defaulting to shell mode." "$FG_RED"
        sleep 1
        shell_loop
        ;;
    esac
  done
}

main() {
  trap 'tput cnorm; exit' INT TERM EXIT
  mode_selector
}

main