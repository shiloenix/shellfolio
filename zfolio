center_line() {
  local text="$1" color="${2:-$RESET}"
  local width; width=$(get_term_width)
  local len=${#text}
  local pad=$(( (width - len) / 2 ))
  (( pad < 0 )) && pad=0
  printf "%*s%b%s%b\n" "$pad" '' "$color" "$text" "$RESET"
}

type_out() {
  local text="$1" delay="${2:-0.012}" color="${3:-$RESET}" i char
  printf "%b" "$color"
  for (( i=0; i<${#text}; i++ )); do
    char="${text:$i:1}"; printf "%s" "$char"; sleep "$delay"
  done
  printf "%b\n" "$RESET"
}

