boot_shell() {
  clr
  local steps=(
    "Initializing terminal..."
    "Loading profile: ${NAME}..."
    "Mounting /dev/skills..."
    "Compiling personality modules..."
    "Starting portfolio shell..."
  )
  for s in "${steps[@]}"; do
    printf "%b[%b OK %b]%b " "$FG_GRAY" "$FG_GREEN" "$FG_GRAY" "$RESET"
    type_out "$s" 0.008 "$FG_GRAY"
    sleep 0.08
  done
  echo
  pause 0.2
  clr
  print_banner_centered
  cmd_whofetch
  say " Type 'help' or '/?' to see available commands. Type 'B' for browser mode." "$FG_GREEN"
  echo
}

shell_loop() {
  boot_shell
  while true; do
    printf "%b%s@%s%b:%b~%b$ " "$FG_GREEN" "$PROMPT_USER" "$PROMPT_HOST" "$RESET" "$FG_CYAN" "$RESET"
    local input
    if ! IFS= read -r input; then echo; break; fi
    input="$(echo "$input" | xargs 2>/dev/null || echo "$input")"
    case "$input" in
      /\?)        cmd_help ;;
      whofetch)   cmd_whofetch ;;
      about)      cmd_about ;;
      skills)     cmd_skills ;;
      projects)   cmd_projects ;;
      experience) cmd_experience ;;
      contact)    cmd_contact ;;
      clear|cls)  clr ;;
      sudo*)      cmd_sudo ;;
      b|B)
        say " Switching to browser mode..." "$FG_CYAN"
        sleep 0.4
        browser_loop
        boot_shell
        ;;
      exit|quit)
        echo
        say " Thanks for stopping by. See you around." "$FG_GRAY"
        echo
        exit 0
        ;;
      "") : ;;
      *)
        echo
        say " $input: command not found" "$FG_RED"
        say " Type '/?' to see available commands." "$FG_GRAY"
        echo
        ;;
    esac
  done
}

read_key() {
  local key="" seq=""
  IFS= read -rsn1 key
  if [[ "$key" == $'\x1b' ]]; then
    IFS= read -rsn2 -t 0.1 seq 2>/dev/null || true
    key="${key}${seq}"
  fi
  printf '%s' "$key"
}

goto()           { printf '\033[%d;%dH' "$1" "$2"; }
hide_cursor()    { printf '\033[?25l'; }
show_cursor()    { printf '\033[?25h'; }
clear_eol()      { printf '\033[K'; }
erase_screen()   { printf '\033[2J'; }

SIDEBAR_W=28
BANNER_ROWS=10

draw_chrome() {
  local rows; rows=$(get_term_height)
  local cols; cols=$(get_term_width)
  local sw=$SIDEBAR_W
  local pw=$(( cols - sw - 1 ))
  local chrome_start=$(( BANNER_ROWS + 1 ))
  local chrome_end="$rows"

  erase_screen

  local ban_row=1
  goto "$ban_row" 1; echo
  (( ban_row++ ))
  for line in "${BANNER_LINES[@]}"; do
    local stripped; stripped=$(printf '%s' "$line" | sed 's/\x1b\[[0-9;]*m//g')
    local len=${#stripped}
    local pad=$(( (cols - len) / 2 ))
    (( pad < 0 )) && pad=0
    goto "$ban_row" 1
    printf "%*s%b%s%b" "$pad" '' "$FG_CYAN" "$line" "$RESET"
    (( ban_row++ ))
  done
  goto "$ban_row" 1; echo
  (( ban_row++ ))

  goto "$chrome_start" 1
  printf "%b╔" "$FG_CYAN"
  printf '═%.0s' $(seq 1 "$sw")
  printf "╦"
  printf '═%.0s' $(seq 1 $(( pw - 1 )))
  printf "╗%b" "$RESET"

  local id_row=$(( chrome_start + 1 ))
  goto "$id_row" 2
  local id_str="${PROMPT_USER}@${PROMPT_HOST}"
  printf "%b%b %-*s%b" "$FG_CYAN" "$BOLD" $(( sw - 2 )) "$id_str" "$RESET"
  goto "$id_row" $(( sw + 1 ))
  printf "%b║%b" "$FG_GRAY" "$RESET"
  goto "$id_row" $(( sw + 2 ))
  printf "%b%b%-*s%b" "$FG_YELLOW" "$DIM" $(( pw - 2 )) "  $ROLE_SHORT" "$RESET"

  local sep_row=$(( chrome_start + 2 ))
  goto "$sep_row" 1
  printf "%b╠" "$FG_GRAY"
  printf '─%.0s' $(seq 1 "$sw")
  printf "╫"
  printf '─%.0s' $(seq 1 $(( pw - 1 )))
  printf "╢%b" "$RESET"

  local r
  for (( r=sep_row+1; r<=chrome_end-1; r++ )); do
    goto "$r" $(( sw + 1 ))
    printf "%b│%b" "$FG_GRAY" "$RESET"
  done

  goto "$chrome_end" 1
  printf "%b╚" "$FG_GRAY"
  printf '═%.0s' $(seq 1 "$sw")
  printf "╩"
  printf '═%.0s' $(seq 1 $(( pw - 1 )))
  printf "╝%b" "$RESET"

  local hint="  ↑↓ navigate     1-6 jump     q quit     Esc Return   "
  local hlen=${#hint}
  local hpos=$(( sw + 2 + (pw - hlen) / 2 ))
  (( hpos < sw + 2 )) && hpos=$(( sw + 2 ))
  goto "$chrome_end" "$hpos"
  printf "%b%b%s%b" "$FG_GRAY" "$DIM" "$hint" "$RESET"
}

draw_sidebar() {
  local selected=$1
  local total=${#BROWSER_ENTRIES[@]}
  local rows; rows=$(get_term_height)
  local sw=$SIDEBAR_W
  local chrome_start=$(( BANNER_ROWS + 1 ))
  local content_start=$(( chrome_start + 3 ))
  local item_start=$content_start

  local r
  for (( r=content_start; r<=rows-1; r++ )); do
    goto "$r" 2
    printf "%*s" $(( sw - 1 )) ''
  done

  goto "$content_start" 2
  printf "%b%b %-*s%b" "$FG_GRAY" "$DIM" $(( sw - 2 )) "  sections" "$RESET"

  local i
  for (( i=0; i<total; i++ )); do
    local row=$(( item_start + 1 + i * 2 ))
    (( row >= rows - 1 )) && break
    local label="${BROWSER_LABELS[$i]}"
    local num=$(( i + 1 ))
    goto "$row" 2
    if (( i == selected )); then
      printf "%b%b  ▶  %d ·  %-*s%b" "$FG_GREEN" "$BOLD" "$num" $(( sw - 9 )) "$label" "$RESET"
    else
      printf "%b     %d ·  %-*s%b" "$FG_GRAY" "$num" $(( sw - 9 )) "$label" "$RESET"
    fi
  done

  local swatch_row=$(( rows - 2 ))
  (( swatch_row > item_start + total * 2 + 2 )) && {
    goto "$swatch_row" 3
    printf "\033[38;5;120m██\033[38;5;80m██\033[38;5;221m██\033[38;5;176m██\033[38;5;203m██\033[0m"
  }
}

